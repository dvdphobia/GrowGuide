<?xml version="1.0" encoding="utf-8"?>
<!-- Modern plant list item card -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_12"
    android:layout_marginVertical="@dimen/space_8"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:cardBackgroundColor="@color/surface"
    app:rippleColor="@color/primary_container">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_16">

        <!-- Plant photo with rounded corners -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/plantPhotoImage"
            android:layout_width="@dimen/plant_photo_size"
            android:layout_height="@dimen/plant_photo_size"
            android:scaleType="centerCrop"
            android:contentDescription="@string/plant_photo"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.GrowGuide.Small"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Plant info section -->
        <LinearLayout
            android:id="@+id/plantInfoLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_16"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/plantPhotoImage"
            app:layout_constraintEnd_toStartOf="@id/chevronIcon"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/plantNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_subtitle"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/plantTypeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_body"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Date with calendar icon -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_8"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/on_surface_variant" />

                <TextView
                    android:id="@+id/plantDateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_4"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

        </LinearLayout>

        <!-- Chevron icon -->
        <ImageView
            android:id="@+id/chevronIcon"
            android:layout_width="@dimen/icon_size"
            android:layout_height="@dimen/icon_size"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/on_surface_variant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
