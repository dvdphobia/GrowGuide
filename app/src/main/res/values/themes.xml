<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material 3 green agricultural theme -->
    <style name="Theme.GrowGuide" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_primary_dark</item>
        <item name="colorPrimaryContainer">@color/green_primary_container</item>
        <item name="colorOnPrimary">@color/green_on_primary</item>
        <item name="colorSecondary">@color/green_secondary</item>
        <item name="colorSurface">@color/green_surface</item>
        <item name="colorOnSurface">@color/green_on_surface</item>
        <item name="android:statusBarColor">@color/green_primary</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <!-- Splash theme - full screen with green background -->
    <style name="Theme.GrowGuide.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="android:statusBarColor">@color/green_primary</item>
        <item name="android:windowBackground">@color/green_primary</item>
    </style>
</resources>
